---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Guides | hospitalbillnegotiationcalc.com';
const description = 'In-depth guides covering key topics at hospitalbillnegotiationcalc.com.';
---
<BaseLayout title={title} description={description}>
  <h1>Guides</h1>
  <p>Plain-language guides written and reviewed by our editorial team.</p>
  <h3><a href="/guides/how-to-negotiate-hospital-bills">How to Negotiate Hospital Bills</a></h3>
  <p>Step-by-step guide to reducing your hospital bill through itemization, error correction, financial assistance, and direct negotiation.</p>
  <h3><a href="/guides/hospital-financial-assistance">Hospital Financial Assistance Programs</a></h3>
  <p>How charity care works, income thresholds, how to apply, and what nonprofit hospitals are required to provide.</p>
  <h3><a href="/guides/medical-billing-errors">Finding and Fixing Medical Billing Errors</a></h3>
  <p>Common billing errors, how to read an EOB, how to dispute charges, and what to do when disputes are denied.</p>
  <h3><a href="/guides/hospital-bill-misconceptions">Common Hospital Bill Misconceptions</a></h3>
  <p>Common misunderstandings about hospital billing: chargemaster rates, insurance coverage, financial assistance, and collections.</p>
  <ul style="margin-top:2rem">
    <li><a href="/case-types">Case types overview</a></li>
    <li><a href="/methodology">Calculator methodology</a></li>
  </ul>
</BaseLayout>
